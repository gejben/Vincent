---
import Layout from "../layouts/Layout.astro";
import MusicCard from "../components/MusicCard.tsx";
import { getTourDates, getDiscography, getSiteSettings, urlFor } from "../lib/sanity";
import { PortableText } from "@portabletext/react";

// ── Fetch CMS data at build time (SSG) ──
let tourDates: any[] = [];
let albums: any[] = [];
let settings: any = null;

try {
  [tourDates, albums, settings] = await Promise.all([
    getTourDates(),
    getDiscography(),
    getSiteSettings(),
  ]);
} catch (e) {
  console.warn("Sanity fetch failed — using fallback content.");
}

const heroImageUrl = settings?.heroImage
  ? urlFor(settings.heroImage).width(1920).height(1080).format("webp").url()
  : null;

// ── Fallback tour dates ──
const fallbackTourDates = [
  { date: "2026-01-24", venue: "Dickens", city: "Fagersta", note: "FAIKdagen" },
  { date: "2026-03-21", venue: "Makeriet", city: "Örebro" },
  { date: "2026-04-11", venue: "Rökbacken", city: "Falun" },
  { date: "2026-05-15", venue: "Våryran", city: "Fagersta" },
  { date: "2026-07-25", venue: "Dan Andersson-veckan", city: "Ludvika" },
  { date: "2026-07-30", venue: "TBA", city: "" },
  { date: "2026-07-31", venue: "John Scotts", city: "Kopparberg" },
  { date: "2026-08-01", venue: "Borgärdets Café", city: "Svärdsjö" },
  { date: "2026-08-02", venue: "TBA", city: "" },
  { date: "2026-08-03", venue: "TBA", city: "" },
  { date: "2026-08-04", venue: "Västervåla kyrka", city: "Västervåla" },
];

const now = new Date();
const upcomingFallbackDates = fallbackTourDates.filter(
  (gig) => new Date(gig.date) >= now
);

// ── Fallback releases (from current site) ──
// Spotify embed URLs: /embed/track/ID or /embed/album/ID with dark theme
const fallbackReleases = [
  { title: "66AN", embedUrl: "https://open.spotify.com/embed/track/6HYADUN0TCZmzuymd8wvwJ?theme=0" },
  { title: "Bergslagen", embedUrl: "https://open.spotify.com/embed/track/0w7uWvMi9KUHfFf00Gtj08?theme=0" },
  { title: "Ahlbäck", embedUrl: "https://open.spotify.com/embed/track/7omQZAr6KZoVrqRw1guy2b?theme=0" },
  { title: "Kom Fattigdom", embedUrl: "https://open.spotify.com/embed/track/2M1C1UgDBbCUbPdesgJJCg?theme=0" },
  { title: "Åmänningen", embedUrl: "https://open.spotify.com/embed/track/4HwCeYaGEoDLfjujuYXrS8?theme=0" },
  { title: "Åka tåg för lånade pengar", embedUrl: "https://open.spotify.com/embed/album/72V3S6286fdOIB3ykPP9Ff?theme=0" },
  { title: "Första", embedUrl: "https://open.spotify.com/embed/album/4KIdygXmd2xm5vsuAq8Jq7?theme=0" },
  { title: "Webcam Stories", embedUrl: "https://open.spotify.com/embed/album/0tdwzfPhnhTWz3NHXLXTQZ?theme=0" },
];

// ── Fallback bio ──
const fallbackBio = [
  "Där den amerikanska södern har sina prärier, har Vincent Jedselius Bergslagens spruckna asfalt och tystnaden från nedlagda fabriker. I mer än ett decennium har han karvat ut en egen nisch i det svenska musiklandskapet som en röst för bruksorterna.",
  "Att kalla Vincent för en renodlad countryartist är en förenkling. Hans sound vilar lika mycket i bluesens enkelhet som i en rå, svensk realism. Här byts Nashville-glamouren ut mot doften av bryggkaffe och fuktig barrskog – musik för de platser som sällan får utrymme i storstädernas popmaskineri.",
  "Med många mil på vägarna har han byggt sin erfarenhet på allt från lokala pizzerior till festivalscener. Genom träffsäker humor och satir skildrar han vardagen i småstaden, men under ytan finns ett allvar om slit, stolthet och den melankoli som dröjer kvar när industrin tystnat.",
  "Vincent Jedselius sjunger om det Sverige som ofta glöms bort, levererat med en ärlig röst och en tydlig kärlek till rötterna.",
];

function getYouTubeId(url: string) {
  if (!url) return "";
  const match = url.match(/[?&]v=([^&]+)/) || url.match(/embed\/([^?]+)/) || url.match(/youtu\.be\/([^?]+)/);
  return match ? match[1] : "";
}

const fallbackYoutubeVideos = [
  { url: "https://www.youtube.com/embed/ILoNFcOGLMY", title: "Kom Fattigdom", description: "Bildmaterial från Rune Lindströms film \"Fagersta: Stålets och arbetets stad.\"" },
  { url: "https://www.youtube.com/embed/YxQ7WmdM3XA", title: "\"66AN\"", description: "Live från Clarion Örebro" },
  { url: "https://www.youtube.com/embed/Kpg47xr6sOw", title: "\"Strömsholms Kanal\"", description: "Live i Halvarsviken" }
];
const fallbackDocumentary = "https://www.youtube.com/embed/B6q9y2d-IBc";

const documentaryVideoUrl = settings?.documentaryVideo || fallbackDocumentary;
const documentaryVideoId = getYouTubeId(documentaryVideoUrl);
const youtubeVideos = settings?.youtubeVideos?.length > 0 ? settings.youtubeVideos : fallbackYoutubeVideos;

// ── Helpers ──
function getSpotifyEmbedUrl(url: string) {
  if (!url) return "";
  // https://open.spotify.com/track/ID -> https://open.spotify.com/embed/track/ID?theme=0
  return url.replace("open.spotify.com/", "open.spotify.com/embed/") + "?theme=0";
}

function formatDateShort(dateStr: string) {
  const d = new Date(dateStr);
  return {
    day: d.toLocaleDateString("sv-SE", { day: "numeric" }),
    month: d.toLocaleDateString("sv-SE", { month: "short" }).toUpperCase(),
  };
}
---

<Layout>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative min-h-screen flex items-start md:items-center justify-center overflow-hidden pt-32 md:pt-0">
    <div class="absolute inset-0">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/hero-mobile.jpg" />
        <img
          src={heroImageUrl || "/images/hero.jpg"}
          alt="Vincent Jedselius vid järnvägen i Bergslagen"
          class="w-full h-full object-cover object-[center_70%] md:object-center"
          loading="eager"
        />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal-950 via-charcoal-950/60 to-transparent" />
    </div>

    <div class="relative z-10 text-center px-6 max-w-3xl">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-bold tracking-tight mb-6">
        Vincent<br />Jedselius
      </h1>
      <p class="text-lg md:text-xl text-bone-300 mb-10 font-light tracking-wide">
        Musik från Bergslagen
      </p>
      <div class="flex items-center justify-center gap-4 mb-10">
        <a
          href="#musik"
          class="inline-flex items-center gap-2 px-8 py-3 bg-forest-700 hover:bg-forest-600 text-bone-100 rounded-full text-sm font-medium uppercase tracking-wider transition-colors duration-300"
        >
          Lyssna nu
        </a>
      </div>
      <!-- Social links -->
      <div class="flex items-center justify-center gap-6 mt-4">
        <a href="https://open.spotify.com/artist/vincent-jedselius" target="_blank" rel="noopener noreferrer" aria-label="Spotify" class="text-bone-300/60 hover:text-forest-500 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        </a>
        <a href="https://youtube.com/@vincentjedselius3461" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-bone-300/60 hover:text-forest-500 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://instagram.com/vincentjedselius/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-bone-300/60 hover:text-forest-500 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://facebook.com/vincentjedselius" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-bone-300/60 hover:text-forest-500 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://tiktok.com/@vincent.jedselius" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-bone-300/60 hover:text-forest-500 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"/></svg>
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-bone-300/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════ TOUR DATES ═══════════════════ -->
  <section id="spelningar" class="py-24 px-6">
    <div class="max-w-[var(--container-max)] mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4 text-center">
        Spelningar
      </h2>
      <p class="text-center text-charcoal-600 text-sm mb-12 tracking-wide uppercase">Turné 2026</p>

      {/* CMS tour dates */}
      {tourDates.length > 0 ? (
        <div class="space-y-3 max-w-2xl mx-auto">
          {tourDates.map((gig: any) => {
            const dateInfo = formatDateShort(gig.date);
            const isSoldOut = gig.isSoldOut;
            const isCancelled = gig.status === "Cancelled";
            const isPostponed = gig.status === "Postponed";

            return (
              <div
                class={`flex items-center gap-6 p-5 rounded-lg border transition-colors duration-200
                  ${isCancelled ? "border-charcoal-800 opacity-50" : "border-charcoal-800 hover:border-forest-700 hover:bg-charcoal-900/50"}`}
              >
                <div class="text-center shrink-0 w-14">
                  <div class="text-xs font-bold tracking-wider text-forest-500">{dateInfo.month}</div>
                  <div class="text-2xl font-heading font-bold">{dateInfo.day}</div>
                </div>

                <div class="flex-1 min-w-0">
                  <h3 class={`font-semibold text-bone-100 ${isCancelled ? "line-through" : ""}`}>
                    {gig.venue}
                  </h3>
                  <p class="text-sm text-charcoal-600">{gig.city}</p>
                </div>

                <div class="shrink-0">
                  {isSoldOut ? (
                    <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-rust/20 text-rust rounded-full">
                      Slutsålt
                    </span>
                  ) : isCancelled ? (
                    <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-charcoal-800 text-charcoal-600 rounded-full">
                      Inställt
                    </span>
                  ) : isPostponed ? (
                    <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-gold/20 text-gold rounded-full">
                      Uppskjutet
                    </span>
                  ) : gig.ticketUrl ? (
                    <a
                      href={gig.ticketUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="px-4 py-2 text-xs font-bold uppercase tracking-wider bg-forest-700 hover:bg-forest-600 text-bone-100 rounded-full transition-colors"
                    >
                      Biljetter
                    </a>
                  ) : null}
                </div>
              </div>
            );
          })}
        </div>
      ) : upcomingFallbackDates.length > 0 ? (
        /* Fallback tour dates (hardcoded) */
        <div class="space-y-3 max-w-2xl mx-auto">
          {upcomingFallbackDates.map((gig) => {
            const dateInfo = formatDateShort(gig.date);
            return (
              <div class="flex items-center gap-6 p-5 rounded-lg border border-charcoal-800 hover:border-forest-700 hover:bg-charcoal-900/50 transition-colors duration-200">
                <div class="text-center shrink-0 w-14">
                  <div class="text-xs font-bold tracking-wider text-forest-500">{dateInfo.month}</div>
                  <div class="text-2xl font-heading font-bold">{dateInfo.day}</div>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-bone-100">
                    {gig.venue}
                    {gig.note && <span class="text-sm font-normal text-charcoal-600 ml-2">({gig.note})</span>}
                  </h3>
                  {gig.city && <p class="text-sm text-charcoal-600">{gig.city}</p>}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <p class="text-center text-bone-300/50 text-lg italic">
          Inga kommande spelningar just nu. Håll utkik!
        </p>
      )}
    </div>
  </section>

  <!-- ═══════════════════ LYSSNA & TITTA ═══════════════════ -->
  <section id="musik" class="py-24 px-6 bg-charcoal-900/40">
    <div class="max-w-[var(--container-max)] mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-16 text-center">
        Lyssna & Titta
      </h2>

      <!-- LYSSNA -->
      <div class="mb-24">
        <h3 class="text-2xl font-heading font-bold mb-8 text-center text-bone-100">Lyssna</h3>
        {albums && albums.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
            {albums.map((album: any) => (
              <iframe
                src={getSpotifyEmbedUrl(album.spotifyUrl || "")}
                title={album.title}
                width="100%"
                height="80"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                class="rounded-lg"
                style="border: 0;"
              ></iframe>
            ))}
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
            {fallbackReleases.map((release) => (
              <iframe
                src={release.embedUrl}
                title={release.title}
                width="100%"
                height="80"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                class="rounded-lg"
                style="border: 0;"
              ></iframe>
            ))}
          </div>
        )}
      </div>

      <!-- TITTA -->
      <div>
        <h3 class="text-2xl font-heading font-bold mb-8 text-center text-bone-100">Titta</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {youtubeVideos.map((video: any) => {
            const vidId = getYouTubeId(video.url);
            return (
              <div>
                <div class="aspect-video rounded-lg overflow-hidden bg-charcoal-800 shadow-xl border border-charcoal-800">
                  <lite-youtube videoid={vidId} playlabel={video.title} class="w-full h-full object-cover"></lite-youtube>
                </div>
                <p class="mt-4 text-sm text-bone-300">
                  <span class="font-heading font-semibold text-bone-100">{video.title}</span>
                  {video.description && <span class="text-charcoal-600"> — {video.description}</span>}
                </p>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ABOUT ═══════════════════ -->
  <section id="om" class="py-24 px-6">
    <div class="max-w-[var(--container-max)] mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-12 text-center">
        Om
      </h2>

      <div class="max-w-4xl mx-auto grid md:grid-cols-[300px_1fr] gap-10 items-start">
        <div class="mx-auto md:mx-0">
          <img
            src="/images/about.jpg"
            alt="Vincent Jedselius"
            width="300"
            height="400"
            loading="lazy"
            class="rounded-lg object-cover w-full max-w-[300px]"
          />
        </div>
        <div>
          {settings?.biography ? (
            <div class="text-bone-300 leading-relaxed text-base space-y-5">
              <PortableText value={settings.biography} client:visible />
            </div>
          ) : (
            <div class="text-bone-300 leading-relaxed text-base space-y-5">
              {fallbackBio.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Pressbilder -->
      <div class="max-w-4xl mx-auto mt-20">
        <h3 class="text-2xl md:text-3xl font-heading font-bold mb-6 text-center">Pressbilder</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {settings?.pressImages?.length > 0 ? (
            settings.pressImages.map((img: any) => {
              const thumbUrl = urlFor(img).width(400).height(500).format("webp").url();
              const fullUrl = urlFor(img).width(1920).format("webp").url();
              return (
                <a href={fullUrl} download target="_blank" rel="noopener noreferrer" class="group block rounded-lg overflow-hidden border border-charcoal-800 hover:border-forest-600 transition-colors">
                  <img src={thumbUrl} alt="Pressbild Vincent Jedselius" loading="lazy" class="w-full h-full object-cover aspect-[4/5] transition-transform duration-300 group-hover:scale-105" />
                </a>
              );
            })
          ) : (
            [
              { src: "/press/portrait.jpg", alt: "Vincent Jedselius porträtt" },
              { src: "/press/lake-guitar.jpg", alt: "Vincent Jedselius vid sjön med gitarr" },
              { src: "/press/tracks-guitar.jpg", alt: "Vincent Jedselius på järnvägsspår med gitarr" },
              { src: "/press/tracks-fullbody.jpg", alt: "Vincent Jedselius på järnvägsspår" },
            ].map((img) => (
              <a href={img.src} download target="_blank" rel="noopener noreferrer" class="group block rounded-lg overflow-hidden border border-charcoal-800 hover:border-forest-600 transition-colors">
                <img src={img.src} alt={img.alt} loading="lazy" class="w-full h-full object-cover aspect-[4/5] transition-transform duration-300 group-hover:scale-105" />
              </a>
            ))
          )}
        </div>
        <p class="mt-4 text-center text-bone-300/60 text-sm">Klicka för att ladda ner i full upplösning.</p>
      </div>

      <div class="max-w-4xl mx-auto mt-20">
        <h3 class="text-2xl md:text-3xl font-heading font-bold mb-6 text-center">Till Bergslagen: Vincent Jedselius och bandet</h3>
        <div class="aspect-video rounded-lg overflow-hidden bg-charcoal-800 shadow-xl border border-charcoal-800">
          <lite-youtube videoid={documentaryVideoId} playlabel="Till Bergslagen" style="max-width: 100%; width: 100%; height: 100%;"></lite-youtube>
        </div>
        <p class="mt-4 text-center text-bone-300 text-lg">
          En liten film om Bergslagen, musik och bruksortsnostalgi.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ CONTACT ═══════════════════ -->
  <section id="kontakt" class="py-24 px-6 bg-charcoal-900/40">
    <div class="max-w-[var(--container-max)] mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4 text-center">
        Kontakt
